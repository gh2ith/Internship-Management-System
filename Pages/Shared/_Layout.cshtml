<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Internship System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="position-relative" style="min-height: 100vh; overflow-x: hidden;">
    <div class="bg-blob"></div>
    <div class="bg-blob-2"></div>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <nav class="navbar navbar-expand-lg sticky-top" style="background: rgba(10, 10, 10, 0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 1000;">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index" style="font-weight: 700; background: linear-gradient(90deg, #ffffff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.5px;">
                    <i class="bi bi-mortarboard-fill me-2" style="background: linear-gradient(135deg, #6c8eff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>InternHub
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: #fff; font-weight: 500;">
                                <img src="https://ui-avatars.com/api/?name=@(User.Identity.Name?.Replace(" ", "+"))&background=111&color=fff&size=32" class="rounded-circle me-2" alt="Avatar" width="32" style="border: 1px solid rgba(167, 139, 250, 0.3);" />
                                <span>@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg premium-dropdown" aria-labelledby="navbarDropdown" style="background: rgba(20, 20, 20, 0.95); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; min-width: 220px; padding: 0.5rem; margin-top: 10px;">
                                <li>
                                    <div class="px-3 py-2">
                                        <small class="text-muted d-block mb-1" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Signed in as</small>
                                        <strong style="color: #fff; font-size: 0.9rem; word-break: break-all;">@User.Identity.Name</strong>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.05); margin: 0.5rem 0;"></li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center" href="#" style="color: #ccc; border-radius: 8px; transition: all 0.2s; padding: 0.5rem 1rem;">
                                        <i class="bi bi-person me-2 text-secondary"></i> My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center" href="#" style="color: #ccc; border-radius: 8px; transition: all 0.2s; padding: 0.5rem 1rem;">
                                        <i class="bi bi-gear me-2 text-secondary"></i> Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.05); margin: 0.5rem 0;"></li>
                                <li>
                                    <form method="post" asp-page="/Account/Logout" class="m-0 p-0">
                                        <button type="submit" class="dropdown-item d-flex align-items-center text-danger w-100 logout-btn" style="border-radius: 8px; transition: all 0.2s; padding: 0.5rem 1rem;">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
