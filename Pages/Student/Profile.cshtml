@page
@model WebApplication1.Pages.Student.ProfileModel
@{
    ViewData["Title"] = "Student Profile";
}

<div class="dashboard-wrapper">
    <div class="container" style="max-width: 900px; padding-top: 1.5rem;">

        <!-- Header -->
        <div class="dashboard-header animate-in d-flex align-items-center gap-3 mb-4">
            <div class="premium-icon-box">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <h1 class="gradient-text" style="font-size: 1.5rem; margin: 0;">Student Profile</h1>
                <p style="color: #666; font-size: 0.85rem; margin: 0;">View your academic details and assigned supervisor information.</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="settings-alert settings-alert-success animate-in delay-1" id="successAlert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@Model.SuccessMessage</span>
                <button type="button" class="settings-alert-close" onclick="this.parentElement.remove()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        }

        <!-- Profile Card -->
        <div class="premium-card animate-in delay-2">
            
            <div class="settings-section-header" style="padding: 1.5rem 2rem;">
                <i class="bi bi-person-badge"></i>
                <div>
                    <h3>Profile Information</h3>
                    <p>Your current academic record and university details</p>
                </div>
            </div>
            
                <form method="post" style="padding: 2.5rem 2rem;">
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="premium-label">Full Name</label>
                            <div class="settings-input-wrapper">
                                <i class="bi bi-person"></i>
                                <input type="text" class="premium-input settings-input" asp-for="FullName" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="premium-label">Department</label>
                            <div class="settings-readonly-field">
                                <i class="bi bi-building"></i>
                                <span>@Model.Department</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="premium-label">GPA</label>
                            <div class="settings-readonly-field">
                                <i class="bi bi-star"></i>
                                <span>@Model.Gpa</span>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="premium-label">Supervisor</label>
                            <div class="settings-readonly-field">
                                <i class="bi bi-person-workspace"></i>
                                <span>@Model.SupervisorName</span>
                                <span class="settings-role-badge">Supervisor</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4 pt-3" style="border-top: 1px solid rgba(123,111,166,0.08);">
                        <button type="submit" class="premium-btn">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Auto-dismiss success alert
    const successAlert = document.getElementById('successAlert');
    if (successAlert) {
        setTimeout(() => {
            successAlert.style.opacity = '0';
            setTimeout(() => successAlert.remove(), 300);
        }, 4000);
    }
</script>
}
