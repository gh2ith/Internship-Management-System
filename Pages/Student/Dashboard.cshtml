@page
@model WebApplication1.Pages.Student.DashboardModel
@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="position-relative" style="min-height: calc(100vh - 80px); overflow: hidden; padding: 2rem 0;">
    <div class="container position-relative z-1 dashboard-wrapper">
        <div class="dashboard-header mb-4 d-flex align-items-center animate-slide-left">
            <div class="premium-icon-box" style="width: 48px; height: 48px; border-radius: 12px; margin-right: 1rem;">
                <i class="bi bi-mortarboard"></i>
            </div>
            <div>
                <h2 class="mb-0 gradient-text">Student Dashboard</h2>
                <p class="text-secondary mb-0" style="font-size: 0.9rem;">Find and apply for your ideal internship</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="settings-alert animate-in delay-1 mb-4" style="background: rgba(255, 107, 107, 0.1); border: 1px solid rgba(255, 107, 107, 0.2); color: #ff6b6b;" id="errorAlert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@Model.ErrorMessage</span>
                <button type="button" class="settings-alert-close" onclick="this.parentElement.remove()" style="color: #ff6b6b;">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        }


        <div class="row">
            <!-- Full Width: Internships & Applications -->
            <div class="col-md-12">
                <ul class="nav nav-tabs mb-4" id="studentTabs" role="tablist" style="border-bottom: 1px solid rgba(123, 111, 166, 0.15);">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="available-tab" data-bs-toggle="tab" data-bs-target="#available-posts" type="button" role="tab" style="background:transparent; color:#fff; font-weight:500; border:none; border-bottom: 2px solid #7B6FA6;">Available Internships</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="apps-tab" data-bs-toggle="tab" data-bs-target="#my-applications" type="button" role="tab" style="background:transparent; color:#777; font-weight:500; border:none;">My Applications</button>
                    </li>

                </ul>

                <div class="tab-content" id="studentTabsContent">
                    
                    <!-- Available Posts Tab -->
                    <div class="tab-pane fade show active" id="available-posts" role="tabpanel">
                        <h5 class="mb-4" style="color:#fff; font-weight:600;">Recent Internship Posts</h5>
                        
                        @if (Model.AvailablePosts.Any())
                        {
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
                                @foreach (var post in Model.AvailablePosts)
                                {
                                    var alreadyApplied = Model.MyApplications.Any(a => a.InternshipId == post.InternshipId);
                                    <div class="premium-internship-card p-4 d-flex flex-column h-100" style="background: rgba(16, 16, 28, 0.6); border: 1px solid rgba(123, 111, 166, 0.15); border-radius: 16px; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden;" onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 12px 30px rgba(0,0,0,0.3), 0 0 0 1px rgba(155, 142, 196, 0.3)';" onmouseout="this.style.transform='none'; this.style.boxShadow='none';">
                                        <!-- Animated Glow Background -->
                                        <div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(155, 142, 196, 0.04) 0%, transparent 50%); z-index: 0; pointer-events: none;"></div>
                                        
                                        <div class="d-flex align-items-center mb-3" style="position: relative; z-index: 1;">
                                            <div class="me-3" style="width: 52px; height: 52px; border-radius: 14px; overflow: hidden; border: 1px solid rgba(123, 111, 166, 0.3); box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                                                <img src="https://ui-avatars.com/api/?name=@(post.Company?.CompanyName?.Replace(" ", "+") ?? "Company")&background=141420&color=9B8EC4&size=52" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;" />
                                            </div>
                                            <div>
                                                <h5 class="mb-0" style="color:#fff; font-weight:700; font-size: 1.15rem; letter-spacing: -0.3px;">@post.Title</h5>
                                                <small style="color:#9B8EC4; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">@post.Company?.CompanyName</small>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3" style="position: relative; z-index: 1;">
                                            @if (post.Deadline.HasValue)
                                            {
                                                <div class="d-inline-flex align-items-center mb-2" style="background: rgba(255, 107, 107, 0.08); color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.2); padding: 0.35rem 0.7rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600;">
                                                    <i class="bi bi-clock-history me-2"></i> Ends @post.Deadline.Value.ToString("MMM dd, yyyy")
                                                </div>
                                            }
                                        </div>
                                        
                                        <p style="color:#aaa; font-size:0.9rem; line-height: 1.6; flex-grow: 1; position: relative; z-index: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                                            @post.Description
                                        </p>
                                        
                                        <div class="mt-3 pt-3 mb-4 border-top" style="border-color: rgba(123, 111, 166, 0.1) !important; position: relative; z-index: 1;">
                                            @if (!string.IsNullOrEmpty(post.Requirments))
                                            {
                                                <span style="color:#666; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 0.6rem; font-weight: 600;">Requirements</span>
                                                <div class="d-flex flex-wrap gap-2">
                                                    <span style="background: rgba(123,111,166,0.08); color: #9B8EC4; border: 1px solid rgba(123,111,166,0.2); padding: 0.3rem 0.7rem; border-radius: 6px; font-size: 0.8rem; font-weight: 500;">@post.Requirments</span>
                                                </div>
                                            }
                                        </div>
                                        
                                        <div class="mt-auto" style="position: relative; z-index: 1;">
                                            @{
                                                var acceptedCount = post.Applications.Count(a => a.Status == 1);
                                                var capacity = post.Capacity ?? 1;
                                                var isClosedOrFull = post.IsClosed == true || acceptedCount >= capacity;
                                            }
                                            
                                            @if (isClosedOrFull)
                                            {
                                                <button class="w-100 premium-btn-outline" style="opacity: 0.5; cursor: not-allowed; border-color: rgba(255, 107, 107, 0.2); padding: 0.75rem; color: #ff6b6b;" disabled title="This post is no longer accepting applications."><i class="bi bi-x-circle-fill me-2"></i> Post Closed</button>
                                            }
                                            else if (alreadyApplied)
                                            {
                                                <button class="w-100 premium-btn-outline" style="opacity: 0.6; cursor: not-allowed; padding: 0.75rem;" disabled><i class="bi bi-check2-all me-2"></i> Successfully Applied</button>
                                            }
                                            else if (Model.HasActiveApplication)
                                            {
                                                <button class="w-100 premium-btn-outline" style="opacity: 0.5; cursor: not-allowed; border-color: rgba(123, 111, 166, 0.2); padding: 0.75rem;" disabled title="You must await supervisor response before applying again."><i class="bi bi-lock-fill me-2 text-secondary"></i> Limit Reached</button>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="Apply" class="w-100" id="applyForm-@post.InternshipId">
                                                    <input type="hidden" name="internshipId" value="@post.InternshipId" />
                                                    <button type="button" class="w-100 premium-btn apply-btn" data-id="@post.InternshipId" data-title="@post.Title" data-company="@(post.Company?.CompanyName ?? "N/A")" data-deadline="@(post.Deadline.HasValue ? post.Deadline.Value.ToString("MMM dd, yyyy") : "No deadline")" style="box-shadow: 0 8px 25px rgba(155, 142, 196, 0.3); padding: 0.75rem; font-weight: 600; font-size: 0.95rem;">
                                                        <i class="bi bi-send-fill me-2"></i> Apply Now
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-inbox" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">No internship posts available</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom: 0;">Check back later when companies post new roles.</p>
                            </div>
                        }
                    </div>

                    <!-- My Applications Tab -->
                    <div class="tab-pane fade" id="my-applications" role="tabpanel">
                        <h5 class="mb-4" style="color:#fff; font-weight:600;">Application Status Tracker</h5>
                        @if (Model.MyApplications.Any())
                        {
                            <div class="premium-table-container shadow-sm">
                                <table class="table-custom mb-0">
                                    <thead>
                                        <tr>
                                            <th>Role</th>
                                            <th>Company</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var app in Model.MyApplications)
                                        {
                                            <tr>
                                                <td style="color:#fff; font-weight:500;">@(app.Internship?.Title ?? "N/A")</td>
                                                <td><i class="bi bi-building me-2 text-secondary"></i>@(app.Comp?.CompanyName ?? "N/A")</td>
                                                <td>
                                                    @if (app.Status == 0)
                                                    {
                                                        <span class="badge-pending"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                                    }
                                                    else if (app.Status == 1)
                                                    {
                                                        <span class="badge-approved"><i class="bi bi-check-circle-fill me-1"></i>Approved</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge-rejected"><i class="bi bi-x-circle-fill me-1"></i>Rejected</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-file-earmark-text" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">You haven't applied to any internships yet</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom: 0;">Go to the Available Internships tab to start applying.</p>
                            </div>
                        }
                        <div class="premium-card p-3 mt-4" style="background: rgba(123,111,166,0.05); border-color: rgba(123,111,166,0.15);">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-info-circle-fill me-3 fs-4" style="color:#7B6FA6;"></i>
                                <div>
                                    <h6 class="mb-1" style="color:#fff; font-size:0.95rem;">Approval Process</h6>
                                    <p class="mb-0" style="color:#aaa; font-size:0.85rem;">The university <strong style="color:#9B8EC4;">Supervisor</strong> reviews and approves/rejects your applications. The Company cannot influence this decision.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Apply Confirmation Modal -->
<div class="modal fade" id="applyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: linear-gradient(135deg, rgba(20, 20, 36, 0.98), rgba(30, 28, 50, 0.98)); border: 1px solid rgba(123, 111, 166, 0.25); border-radius: 20px; backdrop-filter: blur(20px); box-shadow: 0 25px 60px rgba(0,0,0,0.5), 0 0 80px rgba(123, 111, 166, 0.08);">
            <div class="modal-header border-0 pb-0" style="padding: 1.75rem 1.75rem 0;">
                <div class="d-flex align-items-center">
                    <div style="width: 48px; height: 48px; border-radius: 14px; background: rgba(123, 111, 166, 0.12); border: 1px solid rgba(123, 111, 166, 0.25); display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                        <i class="bi bi-send-check" style="font-size: 1.3rem; color: #9B8EC4;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0" style="color: #fff; font-weight: 700; font-size: 1.15rem;">Confirm Application</h5>
                        <small style="color: #888;">Review before submitting</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="opacity: 0.5;"></button>
            </div>
            <div class="modal-body" style="padding: 1.75rem;">
                <div style="background: rgba(123, 111, 166, 0.06); border: 1px solid rgba(123, 111, 166, 0.12); border-radius: 14px; padding: 1.25rem;">
                    <div class="mb-3">
                        <span style="color: #666; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Position</span>
                        <p class="mb-0 mt-1" style="color: #fff; font-weight: 600; font-size: 1.05rem;" id="applyModalTitle"></p>
                    </div>
                    <div class="mb-3">
                        <span style="color: #666; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Company</span>
                        <p class="mb-0 mt-1" style="color: #9B8EC4; font-weight: 500;" id="applyModalCompany"></p>
                    </div>
                    <div>
                        <span style="color: #666; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Deadline</span>
                        <p class="mb-0 mt-1" style="color: #ff6b6b; font-weight: 500;" id="applyModalDeadline"></p>
                    </div>
                </div>
                <div class="mt-3 d-flex align-items-start" style="background: rgba(255, 193, 7, 0.06); border: 1px solid rgba(255, 193, 7, 0.15); border-radius: 10px; padding: 0.85rem 1rem;">
                    <i class="bi bi-info-circle-fill me-2" style="color: #ffc107; margin-top: 2px;"></i>
                    <small style="color: #bbb; line-height: 1.5;">By applying, your application will be sent to the <strong style="color: #9B8EC4;">university supervisor</strong> for review. This action cannot be undone.</small>
                </div>
            </div>
            <div class="modal-footer border-0" style="padding: 0 1.75rem 1.75rem; gap: 0.75rem;">
                <button type="button" class="btn" data-bs-dismiss="modal" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #aaa; border-radius: 10px; padding: 0.6rem 1.5rem; font-weight: 500;">Cancel</button>
                <button type="button" class="premium-btn" id="confirmApplyBtn" style="border-radius: 10px; padding: 0.6rem 1.5rem; font-weight: 600;">
                    <i class="bi bi-send-fill me-2"></i> Confirm & Apply
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentApplyFormId = null;

    document.querySelectorAll('.apply-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            currentApplyFormId = 'applyForm-' + this.dataset.id;
            document.getElementById('applyModalTitle').textContent = this.dataset.title;
            document.getElementById('applyModalCompany').textContent = this.dataset.company;
            document.getElementById('applyModalDeadline').textContent = this.dataset.deadline;
            var modal = new bootstrap.Modal(document.getElementById('applyModal'));
            modal.show();
        });
    });

    document.getElementById('confirmApplyBtn').addEventListener('click', function() {
        if (currentApplyFormId) {
            document.getElementById(currentApplyFormId).submit();
        }
    });

    document.querySelectorAll('.nav-link').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.nav-link').forEach(t => {
                t.style.color = '#777';
                t.style.borderBottom = 'none';
            });
            this.style.color = '#fff';
            this.style.borderBottom = '2px solid #7B6FA6';
        });
    });
</script>
