@page
@model WebApplication1.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="position-relative d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 80px); overflow: hidden;">
    <div class="container position-relative z-1" style="max-width: 420px; width: 100%;">
        <div class="premium-card p-4 p-md-5 animate-in-scale" style="animation: pulseGlow 4s ease-in-out infinite, fadeInScale 0.6s ease-out both;">
            <div class="text-center mb-4">
                <img src="~/images/logo.png" alt="Bridgeway" style="height: 180px; object-fit: contain;" class="mb-4 mx-auto d-block" />
                <h3 class="gradient-text" style="animation: fadeInUp 0.6s ease-out 0.15s both;">Welcome Back</h3>
                <p class="text-secondary" style="font-size: 0.9rem; animation: fadeInUp 0.6s ease-out 0.25s both;">Sign in to Bridgeway</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-4 animate-in delay-3">
                    <label asp-for="Input.Email" class="premium-label">Email</label>
                    <input asp-for="Input.Email" class="form-control premium-input" placeholder="you@university.edu" autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-5 animate-in delay-4">
                    <label asp-for="Input.Password" class="premium-label">Password</label>
                    <input asp-for="Input.Password" class="form-control premium-input" placeholder="Enter your password" autocomplete="current-password" aria-required="true" type="password" />
                    <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="animate-in delay-5">
                    <button id="login-submit" type="submit" class="premium-btn w-100">Sign In <i class="bi bi-arrow-right ms-2"></i></button>
                </div>
            </form>
        </div>

        <p class="text-center mt-4 animate-in delay-6" style="color: rgba(123, 111, 166, 0.5); font-size: 0.8rem;">
            <i class="bi bi-shield-check me-1"></i> Secured by Bridgeway Platform
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
