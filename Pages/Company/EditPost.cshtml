@page "{id:int}"
@model WebApplication1.Pages.Company.EditPostModel
@{
    ViewData["Title"] = "Edit Internship Post";
}

<div class="position-relative" style="min-height: calc(100vh - 80px); overflow: hidden; padding: 3rem 0;">
    <div class="bg-blob"></div>
    <div class="bg-blob-2"></div>
    
    <div class="container position-relative z-1" style="max-width: 850px;">
        <div class="premium-card">
            <div class="premium-header d-flex align-items-center">
                <a asp-page="/Company/Dashboard" class="text-secondary text-decoration-none me-3 transition-colors" style="font-size: 1.5rem;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div class="premium-icon-box">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <h3 class="mb-1">Edit Internship Post</h3>
                    <p class="text-secondary mb-0" style="font-size: 0.9rem;">Update your internship details or change its status</p>
                </div>
            </div>
            
            <div class="p-4 p-md-5">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <label class="premium-label">Job Title *</label>
                            <select id="TitleSelect" class="form-select premium-input mb-3" onchange="toggleCustomTitle()">
                                <option value="" disabled>Select an internship role...</option>
                                <option value="Software Engineering Intern" selected="@(Model.Title == "Software Engineering Intern")">Software Engineering Intern</option>
                                <option value="QA / Software Testing Intern" selected="@(Model.Title == "QA / Software Testing Intern")">QA / Software Testing Intern</option>
                                <option value="Frontend Developer Intern" selected="@(Model.Title == "Frontend Developer Intern")">Frontend Developer Intern</option>
                                <option value="Backend Developer Intern" selected="@(Model.Title == "Backend Developer Intern")">Backend Developer Intern</option>
                                <option value="Data Analyst Intern" selected="@(Model.Title == "Data Analyst Intern")">Data Analyst Intern</option>
                                <option value="UI/UX Design Intern" selected="@(Model.Title == "UI/UX Design Intern")">UI/UX Design Intern</option>
                                <option value="IT Support Intern" selected="@(Model.Title == "IT Support Intern")">IT Support Intern</option>
                                <option value="Other" selected="@(!new[]{"Software Engineering Intern", "QA / Software Testing Intern", "Frontend Developer Intern", "Backend Developer Intern", "Data Analyst Intern", "UI/UX Design Intern", "IT Support Intern"}.Contains(Model.Title))">Other (Please specify)</option>
                            </select>
                            <input id="CustomTitleInput" name="Title" value="@Model.Title" class="form-control premium-input" placeholder="e.g. AI Research Intern" required style="display:none;" />
                            <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="premium-label">Description *</label>
                        <textarea asp-for="Description" class="form-control premium-input" rows="5" placeholder="Describe the role, daily responsibilities, and what the intern will learn..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Requirements" class="premium-label">Requirements</label>
                        <input asp-for="Requirements" class="form-control premium-input" placeholder="e.g. Min GPA 3.0, Basic knowledge of C#, Passion for learning" />
                        <span asp-validation-for="Requirements" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Capacity" class="premium-label">Number of Positions (Capacity) *</label>
                        <input asp-for="Capacity" type="number" min="1" class="form-control premium-input" placeholder="e.g. 1" required />
                        <span asp-validation-for="Capacity" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label class="premium-label">Application Deadline *</label>
                        <div class="d-flex gap-3">
                            <select id="DeadlineYear" class="form-select premium-input" onchange="updateDeadline()" required>
                                <option value="" disabled>Year</option>
                                <option value="@DateTime.Now.Year" selected="@(Model.Deadline?.Year == DateTime.Now.Year)">@DateTime.Now.Year</option>
                                <option value="@(DateTime.Now.Year + 1)" selected="@(Model.Deadline?.Year == DateTime.Now.Year + 1)">@(DateTime.Now.Year + 1)</option>
                                <option value="@(DateTime.Now.Year + 2)" selected="@(Model.Deadline?.Year == DateTime.Now.Year + 2)">@(DateTime.Now.Year + 2)</option>
                            </select>
                            <select id="DeadlineMonth" class="form-select premium-input" onchange="updateDeadline()" required>
                                <option value="" disabled>Month</option>
                                @for(int i=1; i<=12; i++) {
                                    <option value="@i.ToString("D2")" selected="@(Model.Deadline?.Month == i)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                                }
                            </select>
                            <select id="DeadlineDay" class="form-select premium-input" onchange="updateDeadline()" required>
                                <option value="" disabled>Day</option>
                                @for (int i = 1; i <= 31; i++)
                                {
                                    <option value="@i.ToString("D2")" selected="@(Model.Deadline?.Day == i)">@i</option>
                                }
                            </select>
                        </div>
                        <input id="Deadline" name="Deadline" type="hidden" value="@Model.Deadline?.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="Deadline" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-5 p-4 rounded" style="background: rgba(123, 111, 166, 0.05); border: 1px solid rgba(123, 111, 166, 0.2);">
                        <div class="form-check form-switch d-flex align-items-center gap-3">
                            <input class="form-check-input mt-0" type="checkbox" role="switch" id="IsClosed" asp-for="IsClosed" style="width: 3em; height: 1.5em; cursor: pointer;">
                            <label class="form-check-label mb-0" for="IsClosed" style="cursor: pointer;">
                                <strong style="color: #fff;">Close Applications</strong><br>
                                <small style="color: #aaa;">Turning this on will prevent any new students from applying to this post.</small>
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-3 pt-4 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
                        <button type="submit" class="premium-btn"><i class="bi bi-save-fill me-2"></i> Save Changes</button>
                        <a asp-page="/Company/Dashboard" class="premium-btn-outline text-decoration-none">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleCustomTitle() {
            var select = document.getElementById("TitleSelect");
            var customInput = document.getElementById("CustomTitleInput");
            if (select.value === "Other") {
                select.removeAttribute("name");
                customInput.setAttribute("name", "Title");
                customInput.style.display = "block";
                customInput.disabled = false;
            } else {
                select.setAttribute("name", "Title");
                customInput.removeAttribute("name");
                customInput.style.display = "none";
                customInput.disabled = true;
                // If it's not "Other", we need to send the selected value
                customInput.value = select.value;
            }
        }

        function updateDeadline() {
            var y = document.getElementById("DeadlineYear").value;
            var m = document.getElementById("DeadlineMonth").value;
            var d = document.getElementById("DeadlineDay").value;
            var hidden = document.getElementById("Deadline");
            
            if (y && m && d) {
                hidden.value = y + "-" + m + "-" + d;
            } else {
                hidden.value = "";
            }
        }

        // Initialize script on load
        document.addEventListener("DOMContentLoaded", function() {
            var select = document.getElementById("TitleSelect");
            var customInput = document.getElementById("CustomTitleInput");
            if (select.value === "Other") {
                customInput.style.display = "block";
            } else {
                customInput.style.display = "none";
            }
            
            select.addEventListener('change', function() {
                if (this.value !== 'Other') {
                    customInput.value = this.value;
                } else {
                    customInput.value = '';
                }
            });
        });
    </script>
}
