@page
@model WebApplication1.Pages.Company.DashboardModel
@{
    ViewData["Title"] = "Company Dashboard";
}

<div class="position-relative" style="min-height: calc(100vh - 80px); overflow: hidden; padding: 2rem 0;">
    <div class="container position-relative z-1 dashboard-wrapper">
        <div class="dashboard-header mb-4 d-flex align-items-center animate-slide-left">
            <div class="premium-icon-box" style="width: 48px; height: 48px; border-radius: 12px; margin-right: 1rem;">
                <i class="bi bi-building"></i>
            </div>
            <div>
                <h2 class="mb-0 gradient-text">Company Dashboard</h2>
                <p class="text-secondary mb-0" style="font-size: 0.9rem;">Manage your internship postings and applicants</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="settings-alert animate-in delay-1 mb-4" style="background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.2); color: #34d399;" id="successAlert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@Model.SuccessMessage</span>
                <button type="button" class="settings-alert-close" onclick="this.parentElement.remove()" style="color: #34d399; background: transparent; border: none; float: right;">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="settings-alert animate-in delay-1 mb-4" style="background: rgba(255, 107, 107, 0.1); border: 1px solid rgba(255, 107, 107, 0.2); color: #ff6b6b;" id="errorAlert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@Model.ErrorMessage</span>
                <button type="button" class="settings-alert-close" onclick="this.parentElement.remove()" style="color: #ff6b6b; background: transparent; border: none; float: right;">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        }

        <div class="row">
            <!-- Left Column: Company Profile -->
            <div class="col-md-4 mb-4 animate-in delay-1">
                <div class="premium-card p-4">
                    <div class="text-center mb-4">
                        <div class="profile-avatar d-inline-block mb-3">
                            <img src="https://ui-avatars.com/api/?name=@(Model.CompanyInfo?.CompanyName?.Replace(" ", "+") ?? "Company")&background=141420&color=9B8EC4&size=96" class="rounded-circle" alt="Avatar" width="96" height="96" />
                        </div>
                        <h5 class="mb-1" style="color:#fff; font-weight: 600;">@(Model.CompanyInfo?.CompanyName ?? "Company")</h5>
                        <small style="color:#9B8EC4;">@(Model.CompanyInfo?.Description ?? "")</small>
                    </div>
                    <hr class="divider" />
                    <div style="font-size:0.9rem;">
                        <p class="mb-2"><strong class="premium-label" style="display:inline;">Location:</strong> <span style="color:#eee; float:right;">@(Model.CompanyInfo?.Location ?? "N/A")</span></p>
                        <p class="mb-2"><strong class="premium-label" style="display:inline;">Contact:</strong> <span style="color:#eee; float:right;">@(Model.CompanyInfo?.ContactInfo ?? "N/A")</span></p>
                        <p class="mb-0"><strong class="premium-label" style="display:inline;">Active Posts:</strong> <span style="color:#9B8EC4; font-weight:600; float:right;">@Model.Posts.Count</span></p>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="col-md-8">
                <ul class="nav nav-tabs mb-4" role="tablist" style="border-bottom: 1px solid rgba(123,111,166,0.15);">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#my-posts" type="button" role="tab" style="background:transparent; color:#fff; font-weight:500; border:none; border-bottom: 2px solid #7B6FA6;">My Job Posts</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#manage-interns" type="button" role="tab" style="background:transparent; color:#777; font-weight:500; border:none;">Manage Applications</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#evaluations" type="button" role="tab" style="background:transparent; color:#777; font-weight:500; border:none;">Weekly Reports</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#final-evaluation" type="button" role="tab" style="background:transparent; color:#777; font-weight:500; border:none;">Final Evaluation</button>
                    </li>
                </ul>

                <div class="tab-content">
                    
                    <!-- My Posts Tab -->
                    <div class="tab-pane fade show active" id="my-posts" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 style="color:#fff;margin:0;font-weight:600;">Internship Opportunities</h5>
                            <a asp-page="/Company/CreatePost" class="premium-btn text-decoration-none" style="padding: 0.6rem 1.5rem; font-size:0.85rem;"><i class="bi bi-plus-lg me-2"></i> Create Post</a>
                        </div>
                        
                        @if (Model.Posts.Any())
                        {
                            @foreach (var post in Model.Posts)
                            {
                                <div class="premium-card p-4 mb-3 position-relative">
                                    <div class="position-absolute top-0 end-0 p-2 d-flex gap-2 align-items-center" style="z-index: 10;">
                                        <a asp-page="/Company/EditPost" asp-route-id="@post.InternshipId" class="text-secondary text-decoration-none transition-colors d-flex align-items-center justify-content-center" title="Edit Post" style="width: 40px; height: 40px; border-radius: 8px; transition: all 0.2s; cursor: pointer;" onmouseover="this.style.color='#fff'; this.style.background='rgba(255, 255, 255, 0.1)'" onmouseout="this.style.color='#6c757d'; this.style.background='transparent'">
                                            <i class="bi bi-pencil-square fs-5" style="pointer-events: none;"></i>
                                        </a>
                                        <button type="button" onclick="openDeleteModal(@post.InternshipId)" class="btn btn-link m-0 border-0 d-flex align-items-center justify-content-center" title="Delete Post" style="width: 40px; height: 40px; background: transparent; box-shadow: none; color: #ff6b6b; transition: all 0.2s; opacity: 0.8; border-radius: 8px; cursor: pointer;" onmouseover="this.style.opacity='1'; this.style.background='rgba(255, 107, 107, 0.1)'" onmouseout="this.style.opacity='0.8'; this.style.background='transparent'">
                                            <i class="bi bi-trash fs-5" style="pointer-events: none;"></i>
                                        </button>
                                    </div>
                                    <h5 style="color:#fff; font-weight:600; margin-bottom: 0.5rem; padding-right: 70px;">@post.Title</h5>
                                    <p style="color:#aaa; font-size:0.9rem; line-height: 1.6;">@post.Description</p>
                                    <div class="mb-3">
                                        @if (!string.IsNullOrEmpty(post.Requirments))
                                        {
                                            <span class="badge" style="background: rgba(123,111,166,0.08); color: #9B8EC4; border: 1px solid rgba(123,111,166,0.2); font-weight: 500; padding: 0.4rem 0.8rem; border-radius: 8px;">@post.Requirments</span>
                                        }
                                        @if (post.Deadline.HasValue)
                                        {
                                            <span class="badge ms-2" style="background: rgba(123,111,166,0.1); color: #9B8EC4; border: 1px solid rgba(123,111,166,0.2); font-weight: 500; padding: 0.4rem 0.8rem; border-radius: 8px;"><i class="bi bi-calendar-event me-1"></i> Deadline: @post.Deadline.Value.ToString("MMM dd, yyyy")</span>
                                        }
                                    </div>
                                    <hr class="divider" />
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        @{
                                            var acceptedCount = post.Applications.Count(a => a.Status == 1);
                                            var capacity = post.Capacity ?? 1;
                                            var isFull = acceptedCount >= capacity;
                                            var isClosed = post.IsClosed == true || isFull;
                                        }
                                        <div>
                                            <small style="color:#888; display:block;"><i class="bi bi-people me-1"></i> @post.Applications.Count Total Applications</small>
                                            <small style="color:#9B8EC4; font-weight:600;"><i class="bi bi-person-check-fill me-1"></i> @acceptedCount / @capacity Accepted</small>
                                        </div>
                                        <div class="d-flex gap-2 align-items-center">
                                            @if (post.Applications.Count > 0)
                                            {
                                                <a asp-page="/Company/ViewApplicants" asp-route-id="@post.InternshipId" class="premium-btn-outline text-decoration-none" style="padding: 0.4rem 1.2rem; font-size:0.8rem;">View Applicants</a>
                                            }
                                            else
                                            {
                                                <button class="premium-btn-outline" style="padding: 0.4rem 1.2rem; font-size:0.8rem; opacity: 0.5; cursor: not-allowed;" disabled>View Applicants</button>
                                            }
                                        </div>
                                    </div>
                                    @if (isClosed)
                                    {
                                        <div class="w-100 text-center" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(123,111,166,0.2); border-radius: 8px; padding: 0.6rem;">
                                            <small style="color: #666; font-weight:600; text-transform: uppercase; letter-spacing:1px;"><i class="bi bi-lock-fill me-2"></i> Post Closed</small>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-inbox" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">No internship posts yet</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom: 1.5rem;">Create your first post to start accepting applications.</p>
                                <a asp-page="/Company/CreatePost" class="premium-btn text-decoration-none"><i class="bi bi-plus-lg me-2"></i> Create Post</a>
                            </div>
                        }
                    </div>

                    <!-- Manage Interns Tab -->
                    <div class="tab-pane fade" id="manage-interns" role="tabpanel">
                        <h5 class="mb-4" style="color:#fff; font-weight:600;">Student Applications</h5>
                        @if (Model.Applications.Any())
                        {
                            <div class="premium-table-container shadow-sm">
                                <table class="table-custom mb-0">
                                    <thead>
                                        <tr>
                                            <th>Student Name</th>
                                            <th>Role Applied For</th>
                                            <th>GPA</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var app in Model.Applications)
                                        {
                                            <tr>
                                                <td style="color:#fff; font-weight:500;">@(app.Std?.FullName ?? "Unknown")</td>
                                                <td>@(app.Internship?.Title ?? "N/A")</td>
                                                <td>
                                                    <span class="badge" style="background: rgba(123,111,166,0.1); color:#ccc;">@(app.Std?.Gpa?.ToString("F1") ?? "N/A")</span>
                                                </td>
                                                <td>
                                                    @if (app.Status == 0)
                                                    {
                                                        <span class="badge-pending"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                                    }
                                                    else if (app.Status == 1)
                                                    {
                                                        <span class="badge-approved"><i class="bi bi-check-circle-fill me-1"></i>Approved</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge-rejected"><i class="bi bi-x-circle-fill me-1"></i>Rejected</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-people" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">No applications received</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom:0;">Students will appear here once they apply to your roles.</p>
                            </div>
                        }
                        
                        <div class="premium-card p-3 mt-4" style="background: rgba(123,111,166,0.05); border-color: rgba(123,111,166,0.15);">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-info-circle-fill me-3 fs-4" style="color:#7B6FA6;"></i>
                                <div>
                                    <h6 class="mb-1" style="color:#fff; font-size:0.95rem;">Approval Process</h6>
                                    <p class="mb-0" style="color:#aaa; font-size:0.85rem;">Once you post an internship, the university <strong style="color:#9B8EC4;">Supervisor</strong> handles all student approvals and rejections.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Evaluations Tab -->
                    <div class="tab-pane fade" id="evaluations" role="tabpanel">
                        @{
                            var acceptedApps = Model.Applications.Where(a => a.Status == 1).ToList();
                        }
                        @if (!acceptedApps.Any())
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-clipboard-x" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">No accepted interns yet</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom:0;">Weekly reports can only be submitted for students with approved applications.</p>
                            </div>
                        }
                        else
                        {
                            <div class="premium-card p-4 p-md-5 mb-4">
                                <h5 class="mb-2" style="color:#fff; font-weight:600;">Submit Weekly Report</h5>
                                <p style="color:#aaa; font-size:0.9rem; margin-bottom: 2rem;">Submit weekly progress reports for your current interns (8 weeks).</p>

                                <form method="post" asp-page-handler="SubmitWeeklyReport">
                                    <div class="mb-4">
                                        <label class="premium-label">Select Intern</label>
                                        <select name="studentId" id="internSelect" class="form-select premium-input" required>
                                            @foreach (var app in acceptedApps)
                                            {
                                                <option value="@app.StdId" data-submitted="@string.Join(",", Model.SubmittedReports.Where(r => r.StudentId == app.StdId).Select(r => r.WeekNumber))">@(app.Std?.FullName ?? "Unknown") (@(app.Internship?.Title ?? "N/A"))</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-4">
                                        <label class="premium-label">Week Number</label>
                                        <select name="weekNumber" id="weekSelect" class="form-select premium-input" required>
                                            @for (int w = 1; w <= 8; w++)
                                            {
                                                <option value="@w">Week @w</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-4">
                                        <label class="premium-label">Tasks & Activities <span style="color: #ff6b6b;">*</span></label>
                                        <textarea name="task" class="form-control premium-input" rows="4" required placeholder="Describe what the intern worked on this week..."></textarea>
                                    </div>
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <label class="premium-label">Tools Used <span style="color: #ff6b6b;">*</span></label>
                                            <input type="text" name="tools" class="premium-input" required placeholder="e.g., VS Code, MySQL, Git" style="width:100%;" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="premium-label">Hours This Week <span style="color: #ff6b6b;">*</span></label>
                                            <input type="number" name="numberOfHours" class="premium-input" required min="1" max="60" placeholder="e.g., 40" style="width:100%;" />
                                        </div>
                                    </div>
                                    <button type="submit" class="premium-btn w-100"><i class="bi bi-send-fill me-2"></i> Submit Weekly Report</button>
                                </form>
                            </div>

                            <!-- Submitted Reports Timeline -->
                            @if (Model.SubmittedReports.Any())
                            {
                                <div class="premium-card p-4">
                                    <h6 class="mb-4" style="color:#fff; font-weight:600;"><i class="bi bi-journal-check me-2" style="color:#34d399;"></i>Submitted Reports</h6>
                                    @foreach (var report in Model.SubmittedReports.OrderBy(r => r.StudentId).ThenBy(r => r.WeekNumber))
                                    {
                                        <div class="d-flex align-items-start mb-3 p-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(123,111,166,0.1); border-radius: 12px;">
                                            <div style="width: 44px; height: 44px; min-width: 44px; border-radius: 10px; background: rgba(52,211,153,0.1); border: 1px solid rgba(52,211,153,0.2); display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                                                <span style="color: #34d399; font-weight: 700; font-size: 0.85rem;">W@(report.WeekNumber)</span>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <h6 class="mb-1" style="color:#fff; font-weight:600; font-size: 0.9rem;">@(report.Student?.FullName ?? "Student")</h6>
                                                    <span class="badge" style="background: rgba(123,111,166,0.1); color: #9B8EC4; font-size: 0.7rem;">@(report.NumberOfHours ?? 0)h</span>
                                                </div>
                                                <p class="mb-1" style="color:#aaa; font-size:0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@report.Task</p>
                                                <small style="color:#666;">Tools: @report.Tools</small>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- Final Evaluation Tab -->
                    <div class="tab-pane fade" id="final-evaluation" role="tabpanel">
                        @{
                            var evalAccepted = Model.Applications.Where(a => a.Status == 1).ToList();
                        }
                        @if (!evalAccepted.Any())
                        {
                            <div class="premium-card p-5 text-center">
                                <div class="premium-icon-box mx-auto mb-3" style="width: 64px; height: 64px; background: rgba(123,111,166,0.05); border: 1px dashed rgba(123,111,166,0.15);">
                                    <i class="bi bi-star" style="color:#555; background: none; -webkit-text-fill-color: #555;"></i>
                                </div>
                                <h6 style="color:#aaa;">No accepted interns to evaluate</h6>
                                <p style="color:#666; font-size:0.9rem; margin-bottom:0;">Final evaluations can only be submitted for students with approved applications.</p>
                            </div>
                        }
                        else
                        {
                            <!-- Evaluation Form -->
                            <div class="premium-card p-4 mb-4" style="border-color: rgba(245,158,11,0.2);">
                                <div class="d-flex align-items-center mb-4">
                                    <div style="width: 48px; height: 48px; border-radius: 14px; background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25); display: flex; align-items: center; justify-content: center; margin-right: 1rem;">
                                        <i class="bi bi-star-fill" style="font-size: 1.3rem; color: #f59e0b;"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-0" style="color: #fff; font-weight: 700;">Final Evaluation</h5>
                                        <small style="color: #888;">Rate the intern's overall internship performance</small>
                                    </div>
                                </div>

                                <div class="p-3 mb-4" style="background: rgba(59,130,246,0.06); border: 1px solid rgba(59,130,246,0.15); border-radius: 10px;">
                                    <i class="bi bi-info-circle-fill me-2" style="color: #3b82f6;"></i>
                                    <small style="color: #bbb;">This is the final evaluation for the student's internship performance. Once submitted, it cannot be changed.</small>
                                </div>

                                <form method="post" asp-page-handler="SubmitFinalEvaluation">
                                    <div class="mb-4">
                                        <label class="premium-label">Select Intern</label>
                                        <select name="studentId" class="form-select premium-input" required>
                                            @foreach (var app in evalAccepted)
                                            {
                                                var alreadyEvaluated = Model.Evaluations.Any(e => e.StudentId == app.StdId);
                                                if (!alreadyEvaluated)
                                                {
                                                    <option value="@app.StdId">@(app.Std?.FullName ?? "Unknown") — @(app.Internship?.Title ?? "N/A")</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <!-- Rating Table -->
                                    <div class="premium-table-container shadow-sm mb-4" style="overflow: visible;">
                                        <table class="table-custom mb-0" style="table-layout: fixed;">
                                            <thead>
                                                <tr>
                                                    <th style="width: 30%;">Criteria</th>
                                                    <th style="width: 70%; text-align: center;">Rating</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{
                                                    var criteria = new[] {
                                                        new { Name = "performanceLevel", Label = "Performance Level", Desc = "Rate the student's overall work performance" },
                                                        new { Name = "responsibility", Label = "Responsibility", Desc = "Rate the student's sense of responsibility" },
                                                        new { Name = "punctuality", Label = "Punctuality", Desc = "Rate the student's punctuality and attendance" },
                                                        new { Name = "accuracy", Label = "Accuracy in Work", Desc = "Rate the student's accuracy and attention to detail" },
                                                        new { Name = "teamwork", Label = "Teamwork", Desc = "Rate the student's teamwork and collaboration" },
                                                        new { Name = "adaptability", Label = "Adaptability", Desc = "Rate the student's adaptability to new tasks" },
                                                        new { Name = "skillAcquisition", Label = "Skill Acquisition Speed", Desc = "Rate how quickly the student learns new skills" },
                                                        new { Name = "overallCompletion", Label = "Overall Completion", Desc = "Rate the student's overall task completion" }
                                                    };
                                                    var ratings = new[] { "Excellent", "Very Good", "Good", "Acceptable", "Weak" };
                                                    var ratingColors = new[] { "#34d399", "#3b82f6", "#f59e0b", "#f97316", "#ff6b6b" };
                                                }
                                                @foreach (var c in criteria)
                                                {
                                                    <tr>
                                                        <td>
                                                            <strong style="color:#fff; font-size: 0.9rem;">@c.Label</strong><br/>
                                                            <small style="color:#666; font-size: 0.75rem;">@c.Desc</small>
                                                        </td>
                                                        <td>
                                                            <div class="d-flex justify-content-around flex-wrap gap-1">
                                                                @for (int i = 0; i < ratings.Length; i++)
                                                                {
                                                                    var r = ratings[i];
                                                                    var color = ratingColors[i];
                                                                    <label class="d-flex align-items-center gap-1" style="cursor: pointer; white-space: nowrap;">
                                                                        <input type="radio" name="@c.Name" value="@r" required style="accent-color: @color;" />
                                                                        <span style="color: @color; font-size: 0.8rem; font-weight: 500;">@r</span>
                                                                    </label>
                                                                }
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="mb-4">
                                        <label class="premium-label">Additional Comments <small style="color:#666;">(Optional)</small></label>
                                        <textarea name="comments" class="form-control premium-input" rows="3" placeholder="Any additional remarks about the intern's performance..."></textarea>
                                    </div>

                                    <button type="submit" class="premium-btn w-100" style="background: linear-gradient(135deg, #f59e0b, #d97706); padding: 0.75rem; font-weight: 600;">
                                        <i class="bi bi-star-fill me-2"></i> Submit Final Evaluation
                                    </button>
                                </form>
                            </div>

                            <!-- Previously Submitted Evaluations -->
                            @if (Model.Evaluations.Any())
                            {
                                <div class="premium-card p-4">
                                    <h6 class="mb-4" style="color:#fff; font-weight:600;"><i class="bi bi-award-fill me-2" style="color:#f59e0b;"></i>Submitted Evaluations</h6>
                                    @foreach (var ev in Model.Evaluations)
                                    {
                                        <div class="p-3 mb-3" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(245,158,11,0.15); border-radius: 12px;">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <h6 class="mb-0" style="color:#fff; font-weight:600; font-size:0.9rem;">@(ev.Student?.FullName ?? "Student")</h6>
                                                <span class="badge" style="background: rgba(52,211,153,0.1); color: #34d399; font-size: 0.7rem;"><i class="bi bi-check-circle me-1"></i>Evaluated</span>
                                            </div>
                                            <div class="d-flex flex-wrap gap-2">
                                                <span class="badge" style="background: rgba(245,158,11,0.1); color: #f59e0b; font-size: 0.7rem;">Performance: @ev.PerformanceLevel</span>
                                                <span class="badge" style="background: rgba(245,158,11,0.1); color: #f59e0b; font-size: 0.7rem;">Teamwork: @ev.Teamwork</span>
                                                <span class="badge" style="background: rgba(245,158,11,0.1); color: #f59e0b; font-size: 0.7rem;">Overall: @ev.OverallCompletion</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<style>
    .modal, .modal-dialog, .modal-content, .modal-backdrop {
        transition: none !important;
        animation: none !important;
    }
</style>
<div class="modal" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content premium-card" style="background: #141420; border: 1px solid rgba(255, 107, 107, 0.3);">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title" style="color: #ff6b6b; font-weight: 600;"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3 pb-4" style="color: #aaa;">
        Are you sure you want to permanently delete this internship post? This action cannot be undone, and any unaccepted applications tied to this post will be automatically removed.
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="premium-btn-outline" data-bs-dismiss="modal" style="padding: 0.5rem 1.2rem;">Cancel</button>
        <form id="modalDeleteForm" method="post" asp-page-handler="DeletePost" class="m-0 p-0">
            <input type="hidden" id="deleteModalInternshipId" name="internshipId" value="" />
            <button type="button" onclick="document.getElementById('modalDeleteForm').submit();" class="premium-btn" style="background: #ff6b6b; color: white; padding: 0.5rem 1.2rem; border: none; box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);"><i class="bi bi-trash-fill me-2"></i> Delete Post</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
    function openDeleteModal(internshipId) {
        document.getElementById('deleteModalInternshipId').value = internshipId;
        var myModal = new bootstrap.Modal(document.getElementById('deleteModal'));
        myModal.show();
    }

    document.querySelectorAll('.nav-link').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.nav-link').forEach(t => {
                t.style.color = '#777';
                t.style.borderBottom = 'none';
            });
            this.style.color = '#fff';
            this.style.borderBottom = '2px solid #7B6FA6';
        });
    });

    // Filter submitted weeks per intern
    const internSelect = document.getElementById('internSelect');
    const weekSelect = document.getElementById('weekSelect');
    if (internSelect && weekSelect) {
        function updateWeeks() {
            const opt = internSelect.options[internSelect.selectedIndex];
            const submitted = (opt.dataset.submitted || '').split(',').filter(x => x);
            Array.from(weekSelect.options).forEach(wo => {
                const isSubmitted = submitted.includes(wo.value);
                wo.disabled = isSubmitted;
                wo.textContent = isSubmitted ? 'Week ' + wo.value + ' ✓ Submitted' : 'Week ' + wo.value;
            });
            // Auto-select first available week
            const firstAvailable = Array.from(weekSelect.options).find(o => !o.disabled);
            if (firstAvailable) weekSelect.value = firstAvailable.value;
        }
        internSelect.addEventListener('change', updateWeeks);
        updateWeeks();
    }
</script>
